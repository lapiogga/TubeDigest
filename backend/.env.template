# TubeDigest Environment Variables

# Google Cloud OAuth 2.0 Client credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# For Gemini API (3.0 Pro)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (Cloud SQL or Local)
# format: postgresql://user:password@host:port/dbname or mysql+pymysql://...
DATABASE_URL=sqlite:///./tubedigest.db
